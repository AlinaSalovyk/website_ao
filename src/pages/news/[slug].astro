---
import Layout from "@/layouts/Layout.astro";
import { Footer } from "@/components/layout/Footer";
import { Header } from "@/components/layout/Header";
import { ArticlePage } from "@/routes/news/ArticlePage";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n";
import { articleRepository } from "@/lib/strapi/index";
import type { Article } from "@/lib/strapi/types";
import { getArticles, getArticleBySlug } from "@/data/articles";

export async function getStaticPaths() {
  // Strapi first; fall back to static data when Strapi is unavailable
  let articles: Article[] = await articleRepository.findAll();
  if (articles.length === 0) {
    articles = getArticles() as Article[];
  }

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const locale: Locale = "uk";
const t = getTranslations(locale);

const { slug } = Astro.params;
let article: Article | undefined = Astro.props.article;

if (!article) {
  article =
    (await articleRepository.findBySlug(slug as string)) ??
    (getArticleBySlug(slug as string) as Article | undefined);
}

if (!article) {
  return Astro.redirect("/news");
}

// Related articles fetched via repository (encapsulated logic)
const relatedArticles = await articleRepository.findRelated(article.slug, 2);

const siteUrl = Astro.site?.toString()?.replace(/\/$/, "") ?? Astro.url.origin;
const articleUrl = `${siteUrl}/news/${article.slug}/`;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: article.title[locale],
  description: article.summary[locale],
  datePublished: article.date,
  url: articleUrl,
  publisher: {
    "@type": "Organization",
    name: t.meta.siteName,
    url: siteUrl,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl,
  },
};
---

<Layout
  title={`${article.title[locale]} | ${t.meta.siteName}`}
  description={article.summary[locale]}
  ogType="article"
  jsonLdExtra={articleJsonLd}
  locale={locale}
>
  <div
    class="overflow-hidden w-full min-h-screen flex justify-center bg-pure-white"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header
        client:load
        headerPosition="absolute"
        locale={locale}
        currentPath={Astro.url.pathname}
      />
      <main id="main-content" class="w-full">
        <ArticlePage
          client:visible
          article={article}
          relatedArticles={relatedArticles}
          locale={locale}
        />
      </main>
      <Footer client:visible locale={locale} />
    </div>
  </div>
</Layout>
