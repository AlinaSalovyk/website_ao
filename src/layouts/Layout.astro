---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonicalUrl?: string;
}

const {
	title = "ІТБ - Інститут інформаційних технологій та бізнесу",
	description = "Обирай навчання, яке відповідає викликам майбутнього! Інститут інформаційних технологій та бізнесу НаУОА.",
	ogImage = "/images/Home/og-default.jpg",
	canonicalUrl,
} = Astro.props;

const siteUrl = Astro.site?.toString()?.replace(/\/$/, '') ?? '';
const currentUrl = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="uk" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#0f1215" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		{canonicalUrl && <link rel="canonical" href={currentUrl} />}

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:image" content={`${siteUrl}${ogImage}`} />
		<meta property="og:locale" content="uk_UA" />
		<meta property="og:site_name" content="Інститут ІТ та бізнесу НаУОА" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "EducationalOrganization",
			"name": "Інститут інформаційних технологій та бізнесу",
			"alternateName": "ІТБ НаУОА",
			"url": siteUrl,
			"logo": `${siteUrl}/favicon.svg`,
			"description": "Інститут інформаційних технологій та бізнесу Національного університету \"Острозька академія\"",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "вул. Семінарська, 2",
				"addressLocality": "Острог",
				"postalCode": "35800",
				"addressCountry": "UA"
			},
			"telephone": "+380678792526",
			"email": "press@oa.edu.ua",
			"parentOrganization": {
				"@type": "CollegeOrUniversity",
				"name": "Національний університет \"Острозька академія\"",
				"url": "https://www.oa.edu.ua"
			}
		})} />
	</head>
	<body class="antialiased">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[200] focus:top-4 focus:left-4 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:font-medium">Перейти до вмісту</a>
		<slot />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		overflow-x: hidden;
	}

	body {
		background: var(--color-layout-bg);
	}
</style>
