
# ─── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ─── Secrets (generate with: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))")
APP_KEYS=REPLACE_ME,REPLACE_ME,REPLACE_ME,REPLACE_ME
API_TOKEN_SALT=REPLACE_ME
ADMIN_JWT_SECRET=REPLACE_ME
TRANSFER_TOKEN_SALT=REPLACE_ME
ENCRYPTION_KEY=REPLACE_ME

# ─── Database ──────────────────────────────────────────────────────────────

# LOCAL (SQLite — default, no extra config needed)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# PRODUCTION (PostgreSQL on Railway — uncomment and fill these)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=true
# DATABASE_SSL_SELF_SIGNED=false

# ─── Upload provider ───────────────────────────────────────────────────────

# LOCAL — no config needed (files go to public/uploads/)

# PRODUCTION (Cloudinary — set all three to activate)
# CLOUDINARY_NAME=your-cloud-name
# CLOUDINARY_KEY=your-api-key
# CLOUDINARY_SECRET=your-api-secret
# CLOUDINARY_FOLDER=website_ao

# ─── Frontend URL (used for CORS allowlist) ────────────────────────────────
# FRONTEND_URL=https://your-site.vercel.app
